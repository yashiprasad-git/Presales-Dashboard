# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is gitignored - never commit it.

# PostgreSQL connection string from Supabase (Project Settings → Database → Connection string → URI)
# Replace [YOUR-PASSWORD] with your Supabase database password.
DATABASE_URL = "postgresql://postgres:[YOUR-PASSWORD]@db.<your-project-ref>.supabase.co:5432/postgres"

# Monday.com API key (from monday.com → Profile → Developers → My access tokens)
MONDAY_API_KEY = "your_monday_api_key_here"

# OpenAI API key
OPENAI_API_KEY = "your_openai_api_key_here"
